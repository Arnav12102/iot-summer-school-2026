int count = 0;


void setup() {
  pinMode(13, OUTPUT);
  Serial.begin(9600);
}

void loop() {
  digitalWrite(13, HIGH);
  delay(1000);

  digitalWrite(13, LOW);
  delay(1000);

  count++;
// Fixed potentiometer blink interval issue 
  Serial.print("Blink count: ");
  Serial.println(count);
}
